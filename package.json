{
  "name": "mini-program-chat-proxy-demo",
  "version": "1.0.0",
  "private": true,
  "description": "WeChat mini program chat proxy for DeepSeek streaming.",
  "scripts": {
    "start": "node server/index.js",
    "dev:proxy": "node server/index.js",
    "dev:worker": "npx wrangler dev --port 8787",
    "deploy:worker": "npx wrangler deploy",
    "cf:login": "npx wrangler login",
    "cf:secret": "npx wrangler secret put DEEPSEEK_API_KEY"
  },
  "engines": {
    "node": ">=18"
  }
}

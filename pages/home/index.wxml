<view class="home-page">
  <view class="page-bg"></view>
  <view class="page-shell">
    <view
      class="custom-nav"
      style="height: {{navBarHeight}}px; padding-top: {{navStatusBarHeight}}px; padding-right: {{navRightGap}}px;"
    ></view>

    <view class="phone-frame">
      <view class="topbar" style="top: {{navStatusBarHeight}}px; height: {{navContentHeight}}px;">
        <view class="topbar-action" bindtap="handleNewChat">
          <image class="topbar-action-icon" src="/assets/icons/new-chat.svg" mode="aspectFit" />
          <text class="topbar-action-text">{{newChatLabel}}</text>
        </view>
      </view>

      <view class="hero-stack">
        <view class="hero-mascot-layer">
          <image class="hero-mascot-image" src="/bululu.svg" mode="aspectFit" />
        </view>

        <view class="welcome-stage">
          <view class="welcome-hero">
            <view class="welcome-wordmark-wrap">
              <image class="welcome-wordmark" src="/iambululu.svg" mode="aspectFit" />
            </view>
          </view>
        </view>

        <view class="planner-banner">
          <view class="planner-card">
            <view class="planner-heading">
              <text class="planner-heading-text">{{plannerHeading}}</text>
            </view>

            <planner-flow
              scenarios="{{planScenarios}}"
              order="{{planOrder}}"
              initial-plan-key="{{initialPlanKey}}"
              auto-select-first="{{false}}"
              reset-token="{{plannerResetToken}}"
              bindcomplete="handlePlannerComplete"
            />
          </view>
        </view>
      </view>

      <view class="ask-card glass-card">
        <view class="section-heading">
          <view>
            <text class="eyebrow">{{hotQuestionsEyebrow}}</text>
            <text class="section-title">{{hotQuestionsTitle}}</text>
          </view>
        </view>

        <view class="question-list">
          <view
            wx:for="{{hotQuestions}}"
            wx:key="id"
            class="question-item {{selectedQuestionId === item.id ? 'question-item-active' : ''}}"
            data-id="{{item.id}}"
            data-question="{{item.text}}"
            bindtap="pickQuestion"
          >
            <text class="question-item-text">{{item.text}}</text>
            <text class="question-item-arrow">></text>
          </view>
        </view>
      </view>

      <view class="preview-chat">
        <view class="message assistant-message glass-card">
          <text class="message-text">{{assistantMessage}}</text>
        </view>
        <view class="message user-message">
          <text class="message-text">{{previewQuestion}}</text>
        </view>
      </view>

      <view class="composer-panel glass-card">
        <view class="quick-tools">
          <view wx:for="{{quickTools}}" wx:key="*this" class="tool-chip">{{item}}</view>
        </view>

        <view class="composer">
          <view class="voice-button">
            <image class="voice-icon" src="/assets/icons/voice-input.svg" mode="aspectFit" />
          </view>
          <view class="input-shell">
            <input
              class="message-input"
              type="text"
              placeholder="{{composerPlaceholder}}"
              value="{{messageInput}}"
              bindinput="handleInput"
            />
          </view>
        </view>

        <text class="disclaimer">{{disclaimer}}</text>
      </view>
    </view>
  </view>
</view>

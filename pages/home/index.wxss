@import "../../styles/theme.wxss";

.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #d9e4ff 0%, #eaf0ff 100%);
}

.page-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at 12% 18%, rgba(255, 255, 255, 0.7) 0, transparent 26%),
    radial-gradient(circle at 84% 12%, rgba(181, 205, 255, 0.85) 0, transparent 20%),
    radial-gradient(circle at 76% 70%, rgba(225, 196, 255, 0.3) 0, transparent 22%);
  pointer-events: none;
}

.page-shell {
  position: relative;
  min-height: 100vh;
  padding: 0 20rpx 44rpx;
}

.phone-frame {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.custom-nav {
  box-sizing: border-box;
  pointer-events: none;
}

.custom-nav-row {
  display: none;
}

.glass-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 36rpx;
  box-shadow: 0 24rpx 60rpx rgba(87, 111, 175, 0.18);
}

.topbar {
  position: absolute;
  left: 0;
  z-index: 8;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.topbar-action {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-height: 64rpx;
  padding: 0 18rpx 0 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.62);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.4);
}

.nav-action {
  position: relative;
  z-index: 2;
}

.topbar-action-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.topbar-action-text {
  color: #172035;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 600;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.4);
  color: #7f8aa8;
  font-size: 22rpx;
  line-height: 1;
}

.ask-card,
.composer-panel {
  padding: 28rpx;
}

.hero-stack {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.hero-mascot-layer {
  position: absolute;
  top: -82rpx;
  left: -8rpx;
  width: 244rpx;
  height: 476rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 1;
  background: transparent;
}

.hero-mascot-image {
  width: 346rpx;
  height: 486rpx;
  margin-top: -66rpx;
  margin-left: -54rpx;
}

.welcome-stage {
  position: relative;
  z-index: 2;
  min-height: 144rpx;
  padding: 0 6rpx 0;
  background: transparent;
}

.welcome-hero {
  display: flex;
  align-items: flex-start;
  min-height: 144rpx;
  padding-left: 202rpx;
}

.welcome-wordmark-wrap {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  width: 100%;
  min-height: 144rpx;
  padding: 0 12rpx 0 6rpx;
}

.welcome-wordmark {
  width: 100%;
  max-width: 190rpx;
  height: 76rpx;
  margin-top: 0;
}

.planner-banner {
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 3;
  margin-top: -46rpx;
}

.planner-card {
  position: relative;
  overflow: hidden;
  padding: 28rpx 28rpx 28rpx;
  border-radius: 36rpx;
  background: #ffffff;
  border: 1rpx solid rgba(222, 231, 255, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(110, 133, 187, 0.08);
}

.planner-heading {
  display: flex;
  align-items: flex-start;
  min-height: 0;
  margin-bottom: 16rpx;
  padding: 0;
}

.planner-heading-text,
.section-title {
  color: #172035;
  font-size: 32rpx;
  line-height: 1.5;
  font-weight: 600;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.question-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 92rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: rgba(248, 250, 255, 0.96);
  box-shadow: inset 0 0 0 1rpx rgba(231, 236, 255, 0.96);
}

.question-item-active {
  background: rgba(223, 231, 255, 1);
  box-shadow: none;
}

.question-item-text {
  flex: 1;
  color: #172035;
  font-size: 26rpx;
  line-height: 1.6;
}

.question-item-arrow {
  color: #8593b5;
  font-size: 30rpx;
  line-height: 1;
}

.preview-chat {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.message {
  max-width: 88%;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  box-shadow: 0 14rpx 36rpx rgba(109, 131, 187, 0.14);
}

.assistant-message {
  background: rgba(255, 255, 255, 0.86);
}

.user-message {
  align-self: flex-end;
  background: #d9e4ff;
}

.message-text {
  color: #172035;
  font-size: 26rpx;
  line-height: 1.7;
}

.quick-tools {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.tool-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 22rpx;
  background: rgba(226, 234, 255, 0.9);
  box-shadow: inset 0 0 0 1rpx rgba(208, 220, 255, 0.9);
  color: #43506c;
  font-size: 24rpx;
  line-height: 1;
}

.composer {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.voice-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(104, 125, 182, 0.12);
}

.voice-icon {
  width: 42rpx;
  height: 42rpx;
}

.input-shell {
  flex: 1;
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: inset 0 0 0 1rpx rgba(234, 238, 249, 0.96);
}

.message-input {
  width: 100%;
  color: #172035;
  font-size: 26rpx;
  line-height: 1.5;
}

.disclaimer,
.planner-summary {
  display: block;
  margin-top: 18rpx;
  color: #43506c;
  font-size: 22rpx;
  line-height: 1.7;
}

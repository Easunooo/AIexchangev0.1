@import "../../styles/theme.wxss";

.profile-actions {
  margin-top: 22rpx;
}

.todo-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 22rpx;
}

.todo-item {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  padding: 22rpx;
  border-radius: 26rpx;
  background: rgba(246, 248, 255, 1);
}

.todo-index {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: rgba(90, 112, 240, 0.14);
  color: #4d63d4;
  font-size: 22rpx;
  line-height: 1;
}

.todo-main {
  flex: 1;
}

.todo-title {
  display: block;
  color: #17254f;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
}

.todo-copy {
  display: block;
  margin-top: 8rpx;
  color: #54627f;
  font-size: 24rpx;
  line-height: 1.7;
}

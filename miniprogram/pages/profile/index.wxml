<view class="page-shell gradient-page">
  <view class="content-stack">
    <view class="hero-card">
      <text class="eyebrow">\u4f1a\u8bdd\u7ba1\u7406</text>
      <text class="hero-title">\u5386\u53f2\u5bf9\u8bdd</text>
      <text class="hero-copy">
        \u6240\u6709\u5bf9\u8bdd\u90fd\u5b58\u5728\u672c\u5730\u3002\u6253\u5f00\u65e7\u5bf9\u8bdd\u540e\uff0c\u4e4b\u524d\u7684\u7528\u6237\u548c AI \u6d88\u606f\u4f1a\u4e00\u8d77\u5e26\u5165\u4e0b\u4e00\u8f6e\u8bf7\u6c42\uff0c\u4f5c\u4e3a\u4f1a\u8bdd\u8bb0\u5fc6\u3002
      </text>
      <view class="action-row profile-actions">
        <view class="primary-action" bindtap="goHome">\u56de\u5230\u5bf9\u8bdd</view>
        <view class="ghost-action" bindtap="clearAll">{{clearAllLabel}}</view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-heading">
        <view>
          <text class="section-caption">\u672c\u5730\u5386\u53f2</text>
          <text class="section-title">\u5171 {{conversations.length}} \u4e2a\u4f1a\u8bdd</text>
        </view>
      </view>

      <view wx:if="{{conversations.length}}" class="history-list">
        <view
          wx:for="{{conversations}}"
          wx:key="id"
          class="history-item"
          data-conversation-id="{{item.id}}"
          bindtap="openConversation"
        >
          <view class="history-main">
            <text class="history-title">{{item.title}}</text>
            <text class="history-preview">{{item.preview}}</text>
            <text class="history-meta">{{item.updatedLabel}}</text>
          </view>

          <view class="history-side">
            <text class="history-count">{{item.messageCount}}</text>
            <view
              class="history-delete"
              data-conversation-id="{{item.id}}"
              catchtap="deleteConversation"
            >
              \u5220\u9664
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="empty-state">
        <text class="empty-title">{{emptyTitle}}</text>
        <text class="empty-copy">{{emptyCopy}}</text>
      </view>
    </view>
  </view>
</view>
